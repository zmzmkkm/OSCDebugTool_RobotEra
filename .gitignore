# Unity .gitignore核心部分
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/Assets/Framework/Scripts/Editor/




# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Asset meta data should only be ignored when the asset is also ignored
!/[Aa]ssets/**/*.meta
!/[Pp]rojectSettings/**/*.meta
!/[Pp]ackages/**/*.meta

# Autogenerated VS/MD files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.vcxproj
*.vcxproj.filters
#*.dll

# 例外规则（必须放在 *.dll 之后才能生效）
!/Assets/**/OSCsharp.dll

# Unity3D generated meta files
.prefab.meta
.mat.meta
.asset.meta

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*.bin*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*.hash*
/Assets/Framework/Scripts/Editor.meta

# Temporary auto-generated Android Files
**/*.apk
**/*.aab